# Free data sources — most work with no auth. These optional ones unlock more.

# https://www.huduser.gov/hudapi/public/register (free, instant)
HUD_API_TOKEN=

# https://fred.stlouisfed.org/docs/api/api_key.html (free, instant)
FRED_API_KEY=

# https://api.census.gov/data/key_signup.html (free, instant)
CENSUS_API_KEY=

# https://firststreet.org/api (free tier needs registration, optional)
FIRSTSTREET_API_KEY=

# Pikachu legacy: AirDNA + Redfin cookies, only needed for live STR pulls
AIRDNA_TOKENS=
REDFIN_COOKIES=

# Where the duckdb file lives
REIP_DB=./data/reip.duckdb

# Where raw downloads cache
REIP_CACHE=./data/cache
